; Apple Silicon override for native arm64 toolchains. See CLAUDE.md "Local overrides"
; for full setup. Replace YOUR_USERNAME with your macOS login.

[env:uno]
platform_packages =
    toolchain-atmelavr@symlink:///Users/YOUR_USERNAME/.local/pio-avr
    tool-avrdude@symlink:///Users/YOUR_USERNAME/.local/pio-avrdude

[env:uno_r4_minima]
platform_packages =
    toolchain-gccarmnoneeabi@symlink:///Users/YOUR_USERNAME/.local/pio-arm-none-eabi
    tool-bossac@symlink:///Users/YOUR_USERNAME/.local/pio-bossac
